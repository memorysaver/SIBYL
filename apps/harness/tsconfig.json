{
  "$schema": "https://json.schemastore.org/tsconfig",
  "// note": "Standalone config: apps/harness pins TS 5.9.x / @types/node 22.19 to match Pi's toolchain and is kept OUT of the shared Bun catalog (catalog pins typescript ^6). It deliberately does NOT extend @SIBYL/config (which injects @cloudflare/workers-types).",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src", "test", "vitest.config.ts"]
}
